<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_list_item_snmp_interface"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textview_list_item_snmp_interface_no_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/textview_list_item_snmp_interface_margin_top"
        android:layout_marginBottom="@dimen/textview_list_item_snmp_interface_margin"
        android:layout_marginStart="@dimen/textview_list_item_snmp_interface_margin"
        android:layout_marginEnd="@dimen/textview_list_item_snmp_interface_margin"
        android:layout_gravity="center_horizontal"
        android:textStyle="normal"
        android:text="" />

    <androidx.cardview.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:id="@+id/cardview_list_item_snmp_interface"
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/cardview_list_item_snmp_interface_margin"
        card_view:cardCornerRadius="@dimen/cardview_list_item_snmp_interface_corner_radius"
        app:cardElevation="@dimen/cardview_list_item_snmp_interface_card_elevation"
        app:cardBackgroundColor="@color/cardBackgroundColor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/linearlayout_list_item_snmp_interface_padding"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checkbox_list_item_snmp_interface_monitored"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                app:minTouchTargetSize="0dp"
                app:buttonTint="@drawable/checkbox_selector"
                android:checked="false" />

            <TextView
                android:id="@+id/textview_list_item_snmp_interface_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/textview_list_item_snmp_interface_name_margin_start"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="" />

            <TextView
                android:id="@+id/textview_list_item_snmp_interface_second"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/textview_list_item_snmp_interface_second_margin_start"
                android:text="" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
